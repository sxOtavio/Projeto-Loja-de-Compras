<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>📱 MenesPhones | Produtos</title>
    <!-- Latest compiled and minified CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" integrity="sha384-HSMxcRTRxnN+Bdg0JdbxYKrThecOKuH5zCYotlSAcp1+c8xmyTe9GYg1l9a69psu" crossorigin="anonymous">

<!-- Optional theme -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap-theme.min.css" integrity="sha384-6pzBo3FDv/PJ8r2KRkGHifhEocL+1X2rVCTTkUfGk7/0pbek5mMa1upzvWbrUbOZ" crossorigin="anonymous">

<!-- Latest compiled and minified JavaScript -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/js/bootstrap.min.js" integrity="sha384-aJ21OjlMXNL5UyIl/XNwTMqvzeRMZH2w8c5cRVpzpU8Y5bApTppSuUkhZXN0VxHd" crossorigin="anonymous"></script>

    <link rel="stylesheet" href="/css/styleProdutos.css">
</head>
<body>

<!-- HEADER -->
<header class="topo">
    <h1>📱 MenesPhones</h1>
    <nav>
        <a href="/">Home</a>
        <a href="/produtos">Produtos</a>
        <a href="#">Contato</a>
        <a href="/login">Login</a>
    </nav>
</header>

<!-- CONTEÚDO -->
<main class="pagina-produtos">

    <!-- FILTROS -->
    <aside class="filtros">
        <h2>Filtrar</h2>

        <div class="filtro-item">
            <label>Marca</label>
            <select>
                <option>Todas</option>
                <option>Samsung</option>
                <option>Apple</option>
                <option>Xiaomi</option>
                <option>Motorola</option>
            </select>
        </div>

        <div class="filtro-item">
            <label>Preço máximo</label>
            <input type="range" min="500" max="5000">
            <span>Até R$ 5.000</span>
        </div>

        <div class="filtro-item">
            <label>Armazenamento</label>
            <div class="checkbox">
                <input type="checkbox"> 64GB<br>
                <input type="checkbox"> 128GB<br>
                <input type="checkbox"> 256GB
            </div>
        </div>

        <button class="btn-filtrar">Aplicar filtros</button>
    </aside>

    <!-- LISTAGEM -->
    <section class="listagem">

        <!-- ORDENAÇÃO -->
        <div class="ordenacao">
            <label>Ordenar por:</label>
            <select>
                <option>Destaques</option>
                <option>Menor preço</option>
                <option>Maior preço</option>
            </select>
        </div>

        <!-- PRODUTOS -->
        <div class="produtos-grid">
           <% produtos.forEach(function(produto){ %>

            <div class="card-produto">
               <img src="/img/<%= produto.imagem %>" alt="Telefone">
                <h3><%=produto.nome%></h3>
                <p>Marca: <%=produto.marca%></p>
                <p>Memoria interna: <%=produto.armazenamento%></p>
                <span>R$ <%=produto.valor%></span>
                <button>Comprar</button>
            </div>
            
            <% }) %>

           

        
    </section>

</main>

<!-- FOOTER -->
<footer class="rodape">
    <p>© 2026 - PhoneStore</p>
</footer>

</body>
</html>