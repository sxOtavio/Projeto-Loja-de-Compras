<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>📱 MenesPhones</title>
    <link rel="stylesheet" href="/css/stylePrincipal.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <h1>📱 MenesPhones</h1>
        <nav>
            <a href="/">Home</a>
            <a href="/produtos">Produtos</a>
            <a href="">Contato</a>
            <a href="/login">Login</a>
        </nav>
    </header>

    <!-- BANNER -->
    <section class="banner">
        <h2>Os melhores smartphones do mercado</h2>
        <p>Qualidade, preço justo e entrega rápida</p>
    </section>

    <!-- PRODUTOS -->
    <main class="produtos">
                
           <% produtos.forEach(function(produto){ %>
        <div class="card">
            <img src="/img/<%= produto.imagem %>" alt="Telefone">
            <h3><%=produto.nome%></h3>
            <p>Marca: <%=produto.marca%></p>
            <p>Memoria interna: <%=produto.armazenamento%></p>
            <span>R$ <%=produto.valor%></span>
            <button>Comprar</button>
        </div>

         <% }) %>
    </main>

    <!-- FOOTER -->
    <footer>
        <p>© 2026 - MenesPhones | Todos os direitos reservados</p>
    </footer>

</body>
</html>